{
  "name": "deskmate-ai",
  "version": "1.0.0",
  "description": "Local-first modular personal work-wellness hub for computer-heavy workers",
  "main": "./out/main/index.js",
  "author": "DeskMate AI",
  "homepage": "https://app.notion.com/p/Master-Plan-DeskMate-AI-38b8cf3c4aec80f3a3a9dc410e6cb4c7?source=copy_link",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.1",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@lucide/vue": "^1.21.0",
    "@pixiv/three-vrm": "^3.5.4",
    "@pixiv/three-vrm-animation": "^3.5.4",
    "@tailwindcss/vite": "^4.3.1",
    "ai": "^7.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.1.7",
    "get-windows": "^9.3.0",
    "motion-v": "^2.3.0",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.180.0",
    "tw-animate-css": "^1.4.0",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/devtools": "^7.7.10",
    "concurrently": "^10.0.3",
    "electron": "39.8.10",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.6"
  }
}
